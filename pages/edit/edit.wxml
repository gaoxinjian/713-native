<!--pages/edit/edit.wxml-->
<view class="container">
  <view class="form-group">
    <text class="label">转盘名称</text>
    <input 
      class="name-input" 
      value="{{preset.name}}" 
      bindinput="onNameChange"
      placeholder="输入转盘名称"
    />
  </view>

  <view class="form-group">
    <view class="options-header">
      <text class="label">选项列表</text>
      <button class="add-option-btn" bindtap="addOption">+ 添加</button>
    </view>
    
    <view class="probability-info">
      <text class="prob-hint">概率设置（留空则平均分配）</text>
      <text class="prob-sum {{probabilityError ? 'error' : ''}}">当前总和: {{probabilitySum}}%</text>
    </view>
    <text wx:if="{{probabilityError}}" class="prob-error">{{probabilityError}}</text>
    
    <view class="options-list">
      <view class="option-item" wx:for="{{preset.options}}" wx:key="index">
        <input 
          class="option-input"
          value="{{item.label}}"
          data-index="{{index}}"
          bindinput="onOptionChange"
          placeholder="选项内容"
        />
        <view class="probability-input-wrapper">
          <input 
            class="probability-input"
            value="{{item.probability !== null ? item.probability : ''}}"
            data-index="{{index}}"
            bindinput="onProbabilityChange"
            placeholder="自动"
            type="digit"
          />
          <text class="percent">%</text>
        </view>
        <button class="delete-btn" bindtap="deleteOption" data-index="{{index}}">删除</button>
      </view>
    </view>
  </view>

  <button class="save-btn" bindtap="savePreset">保存</button>
</view>